# === Database ===
DATABASE_URL=postgresql://doorium:YOUR_PASSWORD@localhost:5432/doorium_db

# === JWT ===
JWT_SECRET=your_random_secret_here_min_32_chars

# === S3 Object Storage (Timeweb) ===
S3_ENDPOINT=https://s3.timeweb.cloud
S3_REGION=ru-1
S3_BUCKET=doorium
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# === SMS Gateway for Android (https://sms-gate.app) ===
# Локальный режим: URL = http://<публичный_IP_телефона>:8080/message
# Облачный режим:  URL = https://api.sms-gate.app/3rdparty/v1/message
SMS_GATEWAY_URL=http://94.79.18.226:8080/message
SMS_GATEWAY_LOGIN=sms
SMS_GATEWAY_PASSWORD=changeme
NOTIFY_DRIVER=both
SMS_DIAGNOSTIC_DELAY_MS=1500

# === Web Push (VAPID) ===
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === Bridge (inter-CRM exchange) ===
BRIDGE_API_KEY=your_bridge_api_key_min_32_chars
PRIMEDOOR_API_URL=https://api.primedoor.ru
PRIMEDOOR_API_KEY=primedoor_bridge_api_key

# === Server ===
PORT=3001
